# REQUIRED
DIVERA_ACCESSKEY="PASTE_YOUR_DIVERA_ACCESSKEY_HERE"

NTFY_URL="https://ntfy.example.com"
NTFY_TOPIC="fw-alarme-x9k3p"

# OPTIONAL
DIVERA_URL="https://www.divera247.com/api/v2/alarms?accesskey=<API-Key>"
DIVERA_FALLBACK_URL="https://divera247.com/api/v2/alarms?accesskey=<API-Key>"
POLL_SECONDS="20"
STATE_FILE="/var/lib/alarm-gateway/state.json"

# ntfy priority / routing
NTFY_PRIORITY="5"
NTFY_DEFAULT_PRIORITY="5"
# Case-insensitive: MANV/manv/ManV/MANv wird identisch behandelt
NTFY_PRIORITY_KEYWORDS=""
NTFY_AUTH_TOKEN=""
# zusätzliche ntfy Server als Fallback (kommagetrennt)
NTFY_FALLBACK_URLS=""
NTFY_RETRY_ATTEMPTS="2"
NTFY_RETRY_DELAY_SECONDS="1.5"

REQUEST_TIMEOUT="15"
VERIFY_TLS="true"

# Cluster / HA (active node = höchste NODE_PRIORITY)
NODE_ID="gateway-standort-a"
NODE_PRIORITY="100"
# IP/Domain + Port möglich, z. B. 10.8.0.12:8081,ntfy.dataklo.de:8084
PEER_NODES=""
CLUSTER_PING_TIMEOUT="2"
CLUSTER_STATUS_TTL_SECONDS="5"
# optionales Shared-Secret für Health Peer-Checks
CLUSTER_SHARED_TOKEN=""

# Audit Log (JSON Lines), z. B. /var/log/alarm-gateway/audit.log
AUDIT_LOG_FILE=""

# Webhook / Trigger / UI
WEBHOOK_ENABLED="true"
WEBHOOK_BIND="0.0.0.0"
WEBHOOK_PORT="8080"
WEBHOOK_PATH="/webhook/alarm"
WEBHOOK_TRIGGER_PATH="/webhook/trigger"
WEBHOOK_UI_PATH="/"
WEBHOOK_TOKEN=""

# Replay-Schutz für Webhooks (HMAC)
WEBHOOK_REPLAY_PROTECTION="false"
WEBHOOK_MAX_SKEW_SECONDS="120"
WEBHOOK_HMAC_SECRET=""

# Separater Health-Port
HEALTH_ENABLED="true"
HEALTH_BIND="0.0.0.0"
HEALTH_PORT="8081"
HEALTH_PATH="/healthz"
HEALTH_METRICS_PATH="/metrics"
